# GitLab Personal Access Token with `api` scope.
# Create at: https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitLab host. Defaults to gitlab.com. Override for self-hosted instances.
GITLAB_HOST=gitlab.com

# Optional: default project path. When set, you can omit <project> from the CLI.
# Example: REVIEW_PROJECT=mygroup/myrepo
# REVIEW_PROJECT=

# Optional: override the target branch the reviewer is willing to merge into.
# Defaults to "main".
REVIEW_TARGET_BRANCH=main

# Optional: Claude CLI binary. Defaults to `claude`.
CLAUDE_BIN=claude

# Optional: set to 1 for verbose debug logging to stderr.
# REVIEW_DEBUG=1
